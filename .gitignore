# This gitignore file is specifically template for Unity projects.
#
# Contains Unity-specific ignores, IDE files, OS-specific files, and user-generated local folders.

[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Aa]utobuild/
[Pp]roj/
[Ll]ogs/
MemoryCaptures/
UserSettings/

# Asset meta files for folders ignored above
AssetStoreTools/
AssetStoreTools.meta

# Autogenerated VS/MD/Consulo solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D Generated file is constantly updated
sysinfo.txt

# Crashlytics generated file
crashlytics-build.properties

# Packed Mod Assets
*.jack

# macOS system files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Assets/Plugins/
